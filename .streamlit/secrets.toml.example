# Plantilla de secrets para Streamlit.
#
# - En Streamlit Community Cloud: NO subas este archivo con la clave. Pega su
#   contenido (con la clave real) en  App → Settings → Secrets  del panel web.
# - En local: copia este archivo como  .streamlit/secrets.toml  y pon tu clave
#   (ese archivo real está ignorado por git). En local también se lee desde .env.

ANTHROPIC_API_KEY = "sk-ant-api03-..."
HITL_AMOUNT_THRESHOLD = "5000"
